PORT=add_your_port# ===============================
# Server Configuration
# ===============================
PORT=5000

# ===============================
# Redis / Valkey Configuration
# ===============================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ===============================
# Environment
# ===============================
NODE_ENV=development

# ===============================
# Authentication (JWT)
# ===============================
JWT_SECRET=your_secret_here
JWT_EXPIRES_IN=1d

# ===============================
# Rate Limiting
# ===============================
RATE_LIMIT_WINDOW_MS=5000
RATE_LIMIT_MAX_REQUESTS=1


CHECK_COUNT=100000

